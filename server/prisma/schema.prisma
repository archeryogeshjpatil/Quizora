generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ───────────────────────────────────────────────────────────

enum Role {
  ADMIN
  STUDENT
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model User {
  id        String     @id @default(cuid())
  fullName  String
  email     String     @unique
  mobile    String     @unique
  password  String
  role      Role       @default(STUDENT)
  status    UserStatus @default(PENDING)
  language  String     @default("en")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  attempts     TestAttempt[]
  certificates Certificate[]
  bookmarks    Bookmark[]
  batches      BatchStudent[]

  @@map("users")
}

// ─── BATCH / STANDARD ───────────────────────────────────────────────

model Batch {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students BatchStudent[]
  tests    BatchTest[]

  @@map("batches")
}

model BatchStudent {
  id        String @id @default(cuid())
  batchId   String
  studentId String

  batch   Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([batchId, studentId])
  @@map("batch_students")
}

model BatchTest {
  id      String @id @default(cuid())
  batchId String
  testId  String

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  test  Test  @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([batchId, testId])
  @@map("batch_tests")
}

// ─── SUBJECT ────────────────────────────────────────────────────────

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics    Topic[]
  questions Question[]
  tests     Test[]

  @@map("subjects")
}

// ─── TOPIC ──────────────────────────────────────────────────────────

model Topic {
  id          String   @id @default(cuid())
  name        String
  subjectId   String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions Question[]
  tests     Test[]

  @@unique([subjectId, name])
  @@map("topics")
}

// ─── QUESTION ───────────────────────────────────────────────────────

enum QuestionType {
  MCQ
  MSQ
  TRUE_FALSE
  MATCHING
  ASSERTION_REASONING
}

enum Difficulty {
  SIMPLE
  MODERATE
  HARD
  VERY_HARD
}

model Question {
  id             String       @id @default(cuid())
  subjectId      String
  topicId        String?
  type           QuestionType
  difficulty     Difficulty
  text           String       // Rich text (HTML with LaTeX/code)
  imageUrl       String?
  marks          Float        @default(1)
  correctAnswers Json         // Array of correct option IDs or values
  explanation    String?
  version        Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  subject  Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topic    Topic?           @relation(fields: [topicId], references: [id])
  options  QuestionOption[]
  versions QuestionVersion[]
  tests    TestQuestion[]

  @@map("questions")
}

model QuestionOption {
  id         String @id @default(cuid())
  questionId String
  label      String // A, B, C, D, E
  text       String // Rich text
  imageUrl   String?

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

model QuestionVersion {
  id             String     @id @default(cuid())
  questionId     String
  version        Int
  text           String
  options        String     // JSON string
  correctAnswers Json
  marks          Float
  difficulty     Difficulty
  createdAt      DateTime   @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_versions")
}

// ─── TEST ───────────────────────────────────────────────────────────

enum TestType {
  OFFICIAL
  PRACTICE
}

enum TestStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Test {
  id                  String     @id @default(cuid())
  title               String
  subjectId           String
  topicId             String?
  type                TestType   @default(OFFICIAL)
  status              TestStatus @default(DRAFT)
  instructions        String?    // Rich text
  isTimeBased         Boolean    @default(true)
  duration            Int?       // minutes
  autoSubmitOnTimeout Boolean    @default(true)
  startDate           DateTime?
  endDate             DateTime?
  attemptLimit        Int?       // null = unlimited
  marksPerQuestion    Float      @default(1)
  negativeMarking     Boolean    @default(false)
  negativeMarksValue  Float      @default(0)
  questionsPerPage    Int        @default(1)
  allowReview         Boolean    @default(true)
  tabSwitchPrevention Boolean    @default(false)
  tabSwitchAction     String?    // "WARN" or "AUTO_SUBMIT"
  maxTabSwitches      Int?
  webcamProctoring    Boolean    @default(false)
  showResultImmediately Boolean  @default(true)
  resultsPublished    Boolean    @default(false)
  enableCertificate   Boolean    @default(false)
  passingPercentage   Float?
  totalMarks          Float      @default(0)
  msmPartialMarking   Boolean    @default(false) // MSQ partial marking
  matchingPerPair     Boolean    @default(false) // Matching per-pair scoring
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  subject      Subject          @relation(fields: [subjectId], references: [id])
  topic        Topic?           @relation(fields: [topicId], references: [id])
  questions    TestQuestion[]
  attempts     TestAttempt[]
  certificates Certificate[]
  seriesTests  SeriesTest[]
  dispatches   DispatchLog[]
  batches      BatchTest[]

  @@map("tests")
}

model TestQuestion {
  id             String @id @default(cuid())
  testId         String
  questionId     String
  orderIndex     Int
  marksOverride  Float? // Override question default marks

  test     Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([testId, questionId])
  @@map("test_questions")
}

// ─── TEST SERIES ────────────────────────────────────────────────────

enum ScoringMethod {
  SUM
  AVERAGE
  WEIGHTED_AVERAGE
  CUSTOM
}

model TestSeries {
  id                String        @id @default(cuid())
  name              String
  description       String?
  scoringMethod     ScoringMethod @default(SUM)
  customFormula     String?
  enableCertificate Boolean       @default(false)
  passingPercentage Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tests SeriesTest[]

  @@map("test_series")
}

model SeriesTest {
  id         String @id @default(cuid())
  seriesId   String
  testId     String
  orderIndex Int
  weight     Float  @default(1) // for weighted average

  series TestSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  test   Test       @relation(fields: [testId], references: [id])

  @@unique([seriesId, testId])
  @@map("series_tests")
}

// ─── TEST ATTEMPT ───────────────────────────────────────────────────

enum AttemptStatus {
  IN_PROGRESS
  COMPLETED
  AUTO_SUBMITTED
  DISQUALIFIED
}

model TestAttempt {
  id            String        @id @default(cuid())
  testId        String
  studentId     String
  status        AttemptStatus @default(IN_PROGRESS)
  responses     String?       // JSON string of responses
  score         Float?
  totalMarks    Float?
  percentage    Float?
  timeTaken     Int?          // seconds
  tabSwitchCount Int          @default(0)
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?

  test     Test     @relation(fields: [testId], references: [id])
  student  User     @relation(fields: [studentId], references: [id])

  snapshots      ProctoringSnapshot[]
  proctoringFlags ProctoringFlag[]
  bookmarks      Bookmark[]

  @@map("test_attempts")
}

// ─── PROCTORING ─────────────────────────────────────────────────────

model ProctoringSnapshot {
  id         String   @id @default(cuid())
  attemptId  String
  imagePath  String
  capturedAt DateTime @default(now())

  attempt TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("proctoring_snapshots")
}

enum ProctoringFlagType {
  NO_FACE
  MULTIPLE_FACES
  TAB_SWITCH
  QUICK_COMPLETION
}

model ProctoringFlag {
  id        String              @id @default(cuid())
  attemptId String
  type      ProctoringFlagType
  details   String?
  reviewed  Boolean             @default(false)
  action    String?             // ACCEPTED / DISQUALIFIED
  createdAt DateTime            @default(now())

  attempt TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("proctoring_flags")
}

// ─── PLAGIARISM ─────────────────────────────────────────────────────

model PlagiarismFlag {
  id              String  @id @default(cuid())
  testId          String
  studentAId      String
  studentBId      String
  similarityScore Float
  details         String?
  reviewed        Boolean @default(false)
  action          String? // ACCEPTED / DISQUALIFIED
  createdAt       DateTime @default(now())

  @@map("plagiarism_flags")
}

// ─── BOOKMARK ───────────────────────────────────────────────────────

model Bookmark {
  id         String @id @default(cuid())
  studentId  String
  attemptId  String
  questionId String
  createdAt  DateTime @default(now())

  student User        @relation(fields: [studentId], references: [id])
  attempt TestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("bookmarks")
}

// ─── CERTIFICATE ────────────────────────────────────────────────────

model Certificate {
  id            String   @id @default(cuid())
  studentId     String
  testId        String
  certificateId String   @unique // Unique verification ID
  filePath      String
  score         Float
  percentage    Float
  issuedAt      DateTime @default(now())

  student User @relation(fields: [studentId], references: [id])
  test    Test @relation(fields: [testId], references: [id])

  @@unique([studentId, testId])
  @@map("certificates")
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────────

enum NotificationType {
  TEST_AVAILABLE
  TEST_REMINDER
  RESULT_PUBLISHED
  CERTIFICATE_READY
  SERIES_COMPLETED
  AI_GENERATION_COMPLETE
  BULK_IMPORT_COMPLETE
  PROCTORING_ANOMALY
  PLAGIARISM_FLAG
  DISPATCH_EXECUTED
  NEW_REGISTRATION
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  targetRole Role
  targetUserId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ─── DISPATCH LOG ───────────────────────────────────────────────────

enum DispatchStatus {
  PENDING
  SCHEDULED
  SENT
  FAILED
}

enum DispatchChannel {
  EMAIL
  WHATSAPP
  TELEGRAM
}

model DispatchLog {
  id           String          @id @default(cuid())
  testId       String
  studentId    String?
  channel      DispatchChannel
  status       DispatchStatus  @default(PENDING)
  scheduledAt  DateTime?
  sentAt       DateTime?
  errorMessage String?
  createdAt    DateTime        @default(now())

  test Test @relation(fields: [testId], references: [id])

  @@map("dispatch_logs")
}

// ─── AUDIT LOG ──────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
